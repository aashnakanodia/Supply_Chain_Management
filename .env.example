# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000                              # Port the Express server listens on
NODE_ENV=development                   # development | production | test

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost                      # PostgreSQL host
DB_PORT=5432                           # PostgreSQL port
DB_NAME=supply_chain_db                # Database name
DB_USER=postgres                       # Database user
DB_PASSWORD=your_db_password_here      # Database password
DB_POOL_MAX=10                         # Maximum connections in the pool
DB_POOL_IDLE_TIMEOUT=30000             # Milliseconds before idle client is closed

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_secret_access   # Secret for signing access tokens (use: openssl rand -hex 64)
JWT_REFRESH_SECRET=replace_with_64_char_random_secret_refresh # Secret for signing refresh tokens (use: openssl rand -hex 64)
JWT_ACCESS_EXPIRES_IN=15m              # Access token TTL (e.g. 15m, 1h)
JWT_REFRESH_EXPIRES_IN=7d             # Refresh token TTL (e.g. 7d, 30d)

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173       # Allowed origin for CORS (your frontend URL)

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000            # Rate limit window in ms (default: 15 minutes)
RATE_LIMIT_MAX=100                     # Max requests per window per IP

# ── AI Chatbot ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here # Anthropic API key for the AI chatbot
